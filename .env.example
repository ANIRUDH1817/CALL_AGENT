# Groq API Key (Free tier — get it at https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Deepgram API Key (Free $200 credit — get it at https://console.deepgram.com)
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Optional: Webhook URL to send call notes (e.g., Zapier, Make.com, or your own endpoint)
NOTES_WEBHOOK_URL=

# Optional: Twilio credentials (only needed for programmatic call management)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token

# Server port (Render will override this automatically)
PORT=5050
